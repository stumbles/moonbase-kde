          MODULE=marble
         VERSION=26.04.1
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:174bebba04548939f84a274553994f1231917ce437405f0f62050dfd7704ff11
   MODULE_PREFIX=${KDE_INSTALL_DIR:-/usr}
        WEB_SITE=http://marble.kde.org/
         ENTERED=20110813
         UPDATED=20260507
           SHORT="Virtual globe and world atlas"

cat << EOF
Explore the neighborhood with Marble's rich set of city and street level maps.
Search for addresses and places of interest. Marble takes care of querying
various search backends and presents their results in a unified view. Calculate
pedestrian, bike and motorcar routes with ease online and offline, with an
arbitrary number of via points.
EOF
